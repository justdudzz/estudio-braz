# ============================================
# Studio Braz — Variáveis de Ambiente
# ============================================
# NUNCA coloque valores reais aqui. Este ficheiro é um template.
# Copie para .env e preencha com os seus valores.

PORT=5000
NODE_ENV=development

# Base de Dados (PostgreSQL via Docker)
DATABASE_URL="postgresql://postgres:SUA_PASSWORD_AQUI@localhost:5432/studio_braz?schema=public"

# Autenticação
JWT_SECRET="gere_uma_chave_aleatoria_com_64_caracteres_aqui"

# CORS (comma-separated, sem espaços)
# Em desenvolvimento, deixe vazio para usar localhost por defeito
# Em produção: https://estudiobraz.pt
CORS_ORIGINS=

# ============================================
# EMAIL — Nodemailer SMTP
# ============================================
# Preencha quando tiver o domínio/hosting configurado.
# Se vazio, o sistema usa Ethereal (emails de teste).

# SMTP do teu hosting (ex: PTisp, Dominios.pt, cPanel)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Studio Braz <noreply@estudiobraz.pt>"

# Ethereal (teste gratuito — gerar em https://ethereal.email)
ETHEREAL_USER=
ETHEREAL_PASS=

# Scripts de Seed (password para criar o admin)
ADMIN_SEED_PASSWORD=
