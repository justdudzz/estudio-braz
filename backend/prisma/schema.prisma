// MyProject/backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // A linha 'url' foi removida daqui pois agora é gerida pelo prisma.config.ts
}

// Tabela de Clientes: Onde reside a fidelidade
model Client {
  id        String    @id @default(uuid())
  name      String
  
  // 🌟 ALTERAÇÃO DE ELITE: Campos agora são opcionais (?)
  email     String?   @unique
  phone     String?   
  
  password  String?   // Permite acesso ao Salão VIP
  points    Int       @default(0)
  tier      String    @default("Silver") // Silver, Gold, VIP
  notes     String?   // Notas internas sobre o cliente
  bookings  Booking[] // Relação: Uma cliente pode ter vários agendamentos
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([email])
  @@index([name])
  @@index([phone])
}

// Tabela de Agendamentos: A pulsação do estúdio
model Booking {
  id            String    @id @default(uuid())
  date          String   
  time          String   
  service       String
  status        String    @default("pending") // pending, confirmed, paid, completed, cancelled, blocked
  notes         String?   // Notas privadas do admin sobre o booking
  extraServices String?   // JSON array de serviços adicionais
  totalPrice    Float?    // Preço real (serviço principal + extras)
  deletedAt     DateTime? // Soft delete — null = ativo
  
  // Elo de ligação indestrutível (Relacional)
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Previne conflitos de horários e acelera pesquisas
  @@unique([date, time])
  @@index([date])
}

// Tabela do Diretor: Acesso à Fortaleza
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password          String
  role              String   @default("admin")
  twoFactorSecret   String?  // Chave criptográfica para Google Authenticator
  isTwoFactorEnabled Boolean @default(false)
  createdAt         DateTime @default(now())
}